supabase/.temp/
supabase/functions/.env

# ========================
# Archivos grandes (wger dataset)
# ========================
# Los GIFs de wger se descargan bajo demanda, no se suben
**/*.gif
# El JSON de wger puede ser grande — considerar Git LFS si > 100MB
# wger_exercises.json  <- descomenta si prefieres no subirlo

